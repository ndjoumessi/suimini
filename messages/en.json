    "faq": {
      "eyebrow": "Frequently asked questions",
      "title": "Everything you want to know",
      "items": [
        {
          "q": "Is my data secure?",
          "a": "Your data is encrypted in transit (SSL) and hosted in Europe (Supabase, Stockholm). In guest mode, everything stays on your device. You remain the owner of your data and can export it at any time."
        },
        {
          "q": "Can I import a GEDCOM file?",
          "a": "Yes. Suimini imports standard GEDCOM (.ged) files: individuals, families, parent-child relationships and marriages are rebuilt automatically."
        },
        {
          "q": "How does collaboration work?",
          "a": "Invite relatives by email with read or write access. Changes sync in real time and everyone sees who is connected to the tree."
        },
        {
          "q": "Do I need an account to try it?",
          "a": "No. Guest mode works entirely offline with sample data. Create an account only when you want to save to the cloud."
        },
        {
          "q": "Can I export my tree?",
          "a": "Yes: JSON export (full backup), GEDCOM (universal standard) and PDF (list, cards, summary or visual A3 tree)."
        },
        {
          "q": "Is Suimini paid?",
          "a": "The Free plan is enough to get started. The Family and Pro plans unlock cloud sync, sharing and real-time collaboration."
        }
      ]
    },

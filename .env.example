# ============================================================================
# Suimini — Variables d'environnement (référence AUTORITAIRE des secrets)
# Copiez ce fichier en `.env.local` puis renseignez vos clés. `.env.local`
# n'est PAS committé (cf. .gitignore).
#
# Sans les variables Supabase, Suimini tourne à 100% en mode invité (localStorage).
#
# ⚠️ FRONTIÈRES DE SÉCURITÉ (architecture anon-key + RLS) :
#   • NEXT_PUBLIC_* / EXPO_PUBLIC_*  → exposées au navigateur/app (publiques).
#   • Sans préfixe                   → serveur uniquement (routes /api, jamais au client).
#   • Section « CI / GitHub Actions » → secrets de CI UNIQUEMENT. Ne JAMAIS les
#     mettre dans .env.local de l'app ni dans Vercel : ils contournent RLS.
# ============================================================================

# ─── APP · Runtime public (navigateur) ─────────────────────────────────────
# Dashboard Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Couche d'accès données (Phase 0) : 'direct' (navigateur → Supabase, défaut) ou
# 'api' (navigateur → /api/data → Supabase). Rollback = 'direct'. Tant que
# l'ApiDataClient n'est pas livré, 'api' se comporte comme 'direct'.
# NEXT_PUBLIC_DATA_LAYER=direct

# ─── APP · Runtime serveur (routes /api, jamais exposé au navigateur) ───────
# Rapport narratif IA — OPTIONNEL. Sans elle, seul « Générer le rapport » est off.
# https://console.anthropic.com/ → Settings → API Keys
ANTHROPIC_API_KEY=

# Emails transactionnels (approbation / invitation / notif propriétaire) — OPTIONNEL.
# Sans RESEND_API_KEY, les routes email no-op gracieusement (200 { skipped }).
# https://resend.com → API Keys
RESEND_API_KEY=
# Expéditeur vérifié (sinon sandbox onboarding@resend.dev, délivré à la seule
# adresse vérifiée). Ex. "Suimini <no-reply@votre-domaine.fr>"
RESEND_FROM=

# ─── En production (Vercel → Settings → Environment Variables) ──────────────
# Répliquer : NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
#             ANTHROPIC_API_KEY, RESEND_API_KEY, RESEND_FROM.

# ─── MOBILE (mobile/.env — gitignoré ; mapper depuis les NEXT_PUBLIC_*) ─────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# URL d'enregistrement du push token Expo — OPTIONNEL
EXPO_PUBLIC_PUSH_REGISTER_URL=

# ============================================================================
# CI / GitHub Actions — SECRETS PRIVILÉGIÉS (repo → Settings → Secrets/actions)
# ⚠️ Ne JAMAIS placer ces valeurs dans .env.local ni dans Vercel : elles
#    contournent RLS. Elles ne servent QU'en CI (backup, migrations, edge fn).
# ============================================================================
# Personal Access Token Supabase — https://supabase.com/dashboard/account/tokens
# Utilisé par : backup-db.yml, (à venir) migrations auto, déploiement edge functions.
SUPABASE_ACCESS_TOKEN=
# Référence du projet Supabase (Dashboard → Project Settings → General → Reference ID)
SUPABASE_PROJECT_ID=
# Secret partagé pg_cron ↔ Edge Function anniversaires (Bearer). `supabase secrets set CRON_SECRET=…`
CRON_SECRET=

# ─── CI · Tests d'intégration cloud (integration-tests.yml) — OPTIONNEL ─────
# Projet Supabase de TEST séparé (jamais la prod). Voir supabase/test-project.md.
SUPABASE_TEST_URL=
SUPABASE_TEST_ANON_KEY=
SUPABASE_TEST_SERVICE_KEY=

# ─── CI · Alerte d'échec de backup (backup-db.yml) — OPTIONNEL ──────────────
BACKUP_ALERT_EMAIL=

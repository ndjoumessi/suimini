# ============================================================================
# Suimini — Variables d'environnement
# Copiez ce fichier en `.env.local` puis renseignez vos clés Supabase.
# `.env.local` n'est PAS committé (cf. .gitignore).
#
# Sans ces variables, Suimini fonctionne à 100% en mode invité (localStorage).
# ============================================================================

# URL du projet Supabase (Dashboard → Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique "anon" (Dashboard → Project Settings → API → Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ----------------------------------------------------------------------------
# Rapport narratif (IA) — OPTIONNEL
# Clé API Anthropic, utilisée UNIQUEMENT côté serveur (jamais exposée au navigateur).
# Sans elle, l'app marche normalement ; seul « Générer le rapport » est indisponible.
# Obtenir une clé : https://console.anthropic.com/ → Settings → API Keys
# En production : ajoutez-la aussi dans Vercel → Settings → Environment Variables.
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

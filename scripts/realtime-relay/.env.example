# ── Relais temps réel Suimini — variables d'environnement ──────────────────
# Copier en .env pour un run local ; sur Railway, poser ces variables dans le
# service. NE JAMAIS committer un .env réel (gitignoré).

# Port d'écoute (Railway l'injecte automatiquement via PORT).
PORT=8787

# Postgres Railway — URL **DIRECTE (UNPOOLED)** OBLIGATOIRE.
# LISTEN/NOTIFY ne fonctionne PAS à travers PgBouncer (transaction-mode).
# En prod, préférer l'URL du réseau PRIVÉ Railway (*.railway.internal) → pas de TLS
# à épingler (le trafic ne quitte pas le VPC).
RELAY_DATABASE_URL=postgres://user:pass@host.railway.internal:5432/railway

# Validation des jetons (mêmes valeurs que l'app web ; clé ANON publique, JAMAIS service_role).
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Origines autorisées pour le handshake WS (séparées par des virgules). Vide = tout accepter.
RELAY_ALLOWED_ORIGINS=https://suimini.vercel.app,http://localhost:3000

# Coalescence des rafales (ms). Défaut 250.
RELAY_COALESCE_MS=250

# TLS (uniquement si connexion via proxy public *.proxy.rlwy.net, PAS le réseau privé) —
# miroir de src/lib/railwayDb.ts :
#   RAILWAY_DB_CA_CERT="-----BEGIN CERTIFICATE----- …"   # CA épinglé (recommandé hors VPC)
#   RAILWAY_DB_TLS_SERVERNAME=localhost                   # identité attendue du cert Railway
#   RAILWAY_DB_INSECURE_SSL=1                             # repli staging (chiffré, non authentifié)

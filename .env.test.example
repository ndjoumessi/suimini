# ============================================================================
# Suimini — Variables d'environnement pour les tests d'INTÉGRATION réel-cloud
# (e2e/integration/*.spec.ts). Copier en .env.test et remplir avec les clés du
# projet Supabase de TEST dédié (JAMAIS le projet de prod).
#
# ⚠️ NE JAMAIS committer .env.test (secrets). Ce fichier .example ne contient
#    AUCUNE vraie valeur.
#
# Sans ces 3 variables, e2e/integration/*.spec.ts s'auto-skippe (describe.skip)
# → la suite e2e normale reste 100 % verte. Voir supabase/test-project.md.
# ============================================================================

# URL du projet Supabase de TEST (Dashboard → Project Settings → API → Project URL)
SUPABASE_TEST_URL=

# Clé publique "anon" du projet de TEST (Project Settings → API → anon public)
SUPABASE_TEST_ANON_KEY=

# Clé "service_role" du projet de TEST — bypass RLS, réservée au setup/teardown
# des tests. ⚠️ SECRÈTE : jamais dans le client, jamais committée, jamais en prod.
SUPABASE_TEST_SERVICE_KEY=

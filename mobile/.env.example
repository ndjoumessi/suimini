# Supabase — mêmes valeurs que le web (NEXT_PUBLIC_* → EXPO_PUBLIC_*).
# Sans ces variables, l'app tourne en mode démo (arbre « Famille Dupont » local).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optionnel — endpoint d'enregistrement des Expo Push Tokens (défaut :
# https://suimini.vercel.app/api/push/register). À créer côté serveur.
EXPO_PUBLIC_PUSH_REGISTER_URL=
